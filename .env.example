# ── Application ────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
APP_PORT=8080

# ── Database (non-standard port — rule: no well-known ports) ─
DB_HOST=localhost
DB_PORT=15432
DB_NAME=dwsu_erp
DB_USER=erp_app
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── Web (Nginx binds here — rule: no port 80/443/3000) ──────
WEB_PORT=8585

# ── Session & Security ──────────────────────────────────────
SESSION_EXPIRE_HOURS=4
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ── CORS (comma-separated internal origins only) ────────────
ALLOWED_ORIGINS=http://localhost:8585
